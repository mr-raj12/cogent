# Anthropic API key — https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# Optional defaults (can also live in ~/.cogent/settings.json).
# Uncomment to override the built-in default of gemini/gemini-2.5-flash.
# COGENT_PROVIDER=anthropic
# COGENT_MODEL=claude-sonnet-5
