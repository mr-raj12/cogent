{
	"name": "cogent",
	"version": "0.1.0",
	"description": "A minimal coding agent CLI — Gemini + Groq, all tools, session management",
	"type": "module",
	"bin": {
		"cogent": "./dist/index.js"
	},
	"scripts": {
		"dev": "tsx --env-file-if-exists=.env src/index.ts",
		"start": "node --env-file-if-exists=.env dist/index.js",
		"build": "tsc",
		"check": "biome check .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:provider": "tsx --env-file-if-exists=.env test/provider.test.ts",
		"test:tools": "tsx --env-file-if-exists=.env test/tools.test.ts",
		"test:agent": "tsx --env-file-if-exists=.env test/agent.test.ts"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.111.0",
		"@google/genai": "^1.52.0",
		"chalk": "^5.4.1",
		"consola": "^3.4.2",
		"diff": "^8.0.4",
		"glob": "^11.0.0",
		"groq-sdk": "^0.14.0",
		"ignore": "^7.0.5",
		"ink": "^7.1.0",
		"react": "^19.2.7"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.5",
		"@types/diff": "^7.0.1",
		"@types/node": "^22.15.29",
		"@types/react": "^19.2.17",
		"ink-testing-library": "^4.0.0",
		"tsx": "^4.22.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.8"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
